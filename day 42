#include <bits/stdc++.h>
using namespace std;

int main() {
    int N;
    cin >> N;

    queue<int> q;
    stack<int> st;

    // Input
    for (int i = 0; i < N; i++) {
        int x;
        cin >> x;
        q.push(x);
    }

    // Step 1: Queue -> Stack
    while (!q.empty()) {
        st.push(q.front());
        q.pop();
    }

    // Step 2: Stack -> Queue
    while (!st.empty()) {
        q.push(st.top());
        st.pop();
    }

    // Output
    while (!q.empty()) {
        cout << q.front() << " ";
        q.pop();
    }

    return 0;
}
