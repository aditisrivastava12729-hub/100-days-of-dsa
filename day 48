int countLeaves(TreeNode* root) {
    if (!root) return 0;

    stack<TreeNode*> st;
    st.push(root);
    int count = 0;

    while (!st.empty()) {
        TreeNode* curr = st.top();
        st.pop();

        if (!curr->left && !curr->right)
            count++;

        if (curr->left) st.push(curr->left);
        if (curr->right) st.push(curr->right);
    }

    return count;
}
