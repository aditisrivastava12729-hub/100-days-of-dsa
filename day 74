#include <iostream>
#include <map>
using namespace std;

int main() {
    int n;
    cin >> n;

    map<string, int> freq; // keeps keys sorted automatically

    string name;
    for (int i = 0; i < n; i++) {
        cin >> name;
        freq[name]++;
    }

    string winner;
    int maxVotes = 0;

    for (auto it : freq) {
        if (it.second > maxVotes) {
            maxVotes = it.second;
            winner = it.first;
        }
    }

    cout << winner << " " << maxVotes;
    return 0;
}
