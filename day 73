#include <iostream>
#include <unordered_map>
using namespace std;

int main() {
    string s;
    cin >> s;

    unordered_map<char, int> freq;

    // Step 1: Count frequency
    for (char ch : s) {
        freq[ch]++;
    }

    // Step 2: Find first non-repeating character
    for (char ch : s) {
        if (freq[ch] == 1) {
            cout << ch;
            return 0;
        }
    }

    // Step 3: If none found
    cout << '$';
    return 0;
}
