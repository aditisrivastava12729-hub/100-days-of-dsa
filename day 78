#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    vector<vector<pair<int,int>>> adj(n + 1);

    // Input edges
    for (int i = 0; i < m; i++) {
        int u, v, w;
        cin >> u >> v >> w;

        adj[u].push_back({v, w});
        adj[v].push_back({u, w});
    }

    // Min Heap: {weight, node}
    priority_queue<
        pair<int,int>,
        vector<pair<int,int>>,
        greater<pair<int,int>>
    > pq;

    vector<int> visited(n + 1, 0);

    pq.push({0, 1}); // start from node 1
    int totalWeight = 0;

    while (!pq.empty()) {
        auto [wt, node] = pq.top();
        pq.pop();

        if (visited[node]) continue;

        visited[node] = 1;
        totalWeight += wt;

        for (auto &it : adj[node]) {
            int neighbor = it.first;
            int weight = it.second;

            if (!visited[neighbor]) {
                pq.push({weight, neighbor});
            }
        }
    }

    cout << totalWeight;
    return 0;
}
