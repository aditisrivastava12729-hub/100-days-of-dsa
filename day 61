#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    // Initialize n x n adjacency matrix with 0
    vector<vector<int>> adj(n, vector<int>(n, 0));

    for(int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;

        // Assuming 1-based input. Convert to 0-based for matrix
        u--; v--;

        // For directed graph
        adj[u][v] = 1;

        // Uncomment below for undirected graph
        // adj[v][u] = 1;
    }

    // Print adjacency matrix
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            cout << adj[i][j] << " ";
        }
        cout << "\n";
    }
}
