def has_cycle(n, adj):
    visited = [False] * n

    def dfs(node, parent):
        visited[node] = True
        for neighbor in adj[node]:
            if not visited[neighbor]:
                if dfs(neighbor, node):
                    return True
            elif neighbor != parent:
                return True
        return False

    for i in range(n):
        if not visited[i]:
            if dfs(i, -1):
                return "YES"
    return "NO"


# Example usage
n = 5
adj = [
    [1],
    [0, 2],
    [1, 3],
    [2, 4],
    [3, 1]  # creates a cycle
]

print(has_cycle(n, adj))  # Output: YES
