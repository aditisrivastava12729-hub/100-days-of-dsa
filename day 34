class Node:
    def __init__(self, data):
        self.data = data
        self.next = None


class Stack:
    def __init__(self):
        self.top = None

    def push(self, data):
        new = Node(data)
        new.next = self.top
        self.top = new

    def pop(self):
        if self.top is None:
            return None
        temp = self.top
        self.top = self.top.next
        return temp.data


def evaluate_postfix(expr):
    stack = Stack()
    tokens = expr.split()

    for token in tokens:

        if token.isdigit():
            stack.push(int(token))

        else:
            op2 = stack.pop()
            op1 = stack.pop()

            if token == '+':
                stack.push(op1 + op2)
            elif token == '-':
                stack.push(op1 - op2)
            elif token == '*':
                stack.push(op1 * op2)
            elif token == '/':
                stack.push(op1 // op2)

    return stack.pop()


expr = input("Enter postfix expression: ")
print("Result:", evaluate_postfix(expr))
