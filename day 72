#include <iostream>
#include <unordered_set>
using namespace std;

int main() {
    string s;
    cin >> s;

    unordered_set<char> seen;

    for (char ch : s) {
        if (seen.find(ch) != seen.end()) {
            cout << ch;
            return 0;
        }
        seen.insert(ch);
    }

    cout << -1;
    return 0;
}
